<user age> is a number:
  valid values:
    1 year ... 130 years
  question:
    ask "What is your age"

<Age assessment> is a plan:
  during plan:
    assess <user age>:
      1 year ... 18 years:
        show message "Quite young"
      19 years ... 80 years:
        show message "Best age"
      81 years ... 130 years:
        show message "Quite old"
