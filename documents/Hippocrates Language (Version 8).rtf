\f5\b \cf2     \ul assess unit >\
\ulnone       \ul "tablet"; "mg"; "drop" > unit is valid. <<\ulnone \
\pard\pardeftab720\partightenfactor0

\f4\b0 \cf2   ...\
<\
\
...\
\pard\pardeftab720\partightenfactor0

\f5\b \cf2 \ul \ulc2 dose = 1 tablet.\
