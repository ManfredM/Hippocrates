\fs40 \cf2 Simple adherence reminder\
\pard\pardeftab720\partightenfactor0

\fs22 \cf2 \
\pard\pardeftab720\partightenfactor0

\f3\i \cf5 "simple" is a plan:\
  30 minutes before breakfast, 30 minutes before dinner:\
     show message to patient "Please take your dose now":\
       message expires after 30 minutes.\
\pard\pardeftab720\partightenfactor0

\f2 \cf2 \
\
\pard\pardeftab720\partightenfactor0

\f1\i0\fs40 \cf2 More complex adherence reminder with automatic extension of a period\
\pard\pardeftab720\partightenfactor0

\f2\i\fs22 \cf2 \
\pard\pardeftab720\partightenfactor0

\f3 \cf5 "infection prevention" is a plan:\
\
  "antibiotics" for 9 days, can be extended to 14 days:\
    30 minutes before breakfast, 30 minutes before dinner:\
      show message to patient "Please take your dose now":\
        message expires after 30 minutes.\
\
    every second day with begin of breakfast:\
      show message to patient "Please take the full dose\
          of antibiotics to avoid creating resistant germs".\
\
  after antibiotics:\
    ask "How many tablets do you still have?":\
      0 ... 2:\
        show message "Thank you for taking the full dose of \
          antibiotics".\
      3 ... 20:\
        assess current duration of antibiotics:\
          0 days ... 8 days:\
            do nothing.\
          9 days ... 13 days:\
            show message to patient "Please take all of the\
              antibiotics to avoid creating resistant germs".\
            extend current antibiotics period by 1 day.\
          14 days:\
            show message to patient "You still seem to have too\
              many tablets remaining. Please see your \
              physician for further consultation."\
            stop plan.\
\pard\pardeftab720\partightenfactor0

\f1\i0 \cf2 \
\
\pard\pardeftab720\partightenfactor0

\fs40 \cf2 An assessment of the respiratory rate and translation into a meaning according to age\
\pard\pardeftab720\partightenfactor0

\f2\i\fs22 \cf2 \
\pard\pardeftab720\partightenfactor0

\f4\i0 \cf5 #------------------------------------------------------------------------\
\
\pard\pardeftab720\partightenfactor0

\f3\i \cf5 "\cf6 age\cf5 " is a value:\
  valid unit is years.\
  valid values are between (0 years ... 150 years).\
  confidence of \cf6 age\cf5  is:\
    0 years ...  90 years:\
      confidence of value = 100%.\
    91 years ... 100 years:\
      confidence of value = 90%.\
    101 years ... 150 years:\
      confidence of value is 70%.\
  question to get age:\
    ask "Please provide your age in years".\
\pard\pardeftab720\partightenfactor0

\f4\i0 \cf5 \
#------------------------------------------------------------------------\
\
\pard\pardeftab720\partightenfactor0

\f3\i \cf5 "\cf6 pediatric age\cf5 " ia a value:\
  valid unit is months.\
  valid values are between (0 months ... 12 months).\
  question to get \cf6 pediatric age\cf5 :\
    ask patient "Please provide the age in months".\
\
\pard\pardeftab720\partightenfactor0

\f4\i0 \cf5 #------------------------------------------------------------------------\
\
\pard\pardeftab720\partightenfactor0

\f3\i \cf5 "\cf6 respiratory rate\cf5 " is a value:\
  value unit is (breaths per minute, BsPM):\
    1 breaths per minute = 1 BsPM.\
    1 BsPM = 1 breaths per minute.\
  valid values are between (0 BsPM... 100 BsPM).\
\
  meaning of \cf6 respiratory rate\cf5 :\
    assess \cf6 age\cf5 :\
      \cf6 age\cf5  is 0 years:\
        assess \cf6 pediatric age\cf5 :\
          \cf6 pediatric age\cf5  is between (0 months ... 2 months):\
            assess \cf6 respiratory rate\cf5 :\
              0 BsPM ... 19 BsPM:\
                meaning = "critically low".\
              20 BsPM... 29 BsPM:\
                meaning = "low".\
              30 BsPM ... 60 BsPM:\
                meaning = "normal".\
              61 BsPM ... 80 BsPM:\
                meaning = "high".\
              81 BsPM ... 100 BsPM:\
                meaning = "critically high".\
          \cf6 pediatric age\cf5  is between (3 months ... 12 months):\
            assess \cf6 respiratory rate\cf5 :\
              0 BsPM ... 19 BsPM:\
                meaning = "critically low".\
              20 BsPM ... 29 BsPM:\
                meaning = "low". \
              24 BsPM ...  30 BsPM:\
                meaning = "normal". \
              31 BsPM ...  50 BsPM:\
                meaning = "high". \
              51 BsPM ... 100 BsPM:\
                meaning = "critically high".\
      \cf6 age\cf5  is between (1 year ... 5 years):\
        assess \cf6 respiratory rate\cf5 :\
          0 BsPM ... 14 BsPM:\
            meaning = "critically low".\
          15 BsPM ... 19 BsPM:\
            meaning = "low".\
          20 BsPM ... 30 BsPM:\
            meaning = "normal".\
          31 BsPM ... 40 BsPM:\
            meaning = "high".\
          41 BsPM ... 100 BsPM:\
            meaning = "critically high".\
      \cf6 age\cf5  is between (6 years ... 12 years):\
        assess respiratory rate:\
          0 BsPM ... 5 BsPM:\
            meaning = "critically low".\
          6 BsPM ... 11 BsPM:\
            meaning = "low".\
          12 BsPM ... 20 BsPM:\
            meaning = "normal".\
          21 BsPM ...  30 BsPM:\
            meaning = "high".\
          31 BsPM ... 100 BsPM:\
            meaning = "critically high".\
      \cf6 age\cf5  is between (13 years ... 150 years):\
        assess respiratory rate:\
          0 BsPM ... 5 BsPM:\
            meaning = "critically low".\
          6 BsPM ... 11 BsPM:\
            meaning = "low". \
          12 BsPM ... 16 BsPM:\
            meaning = "normal". \
          17 BsPM ... 30 BsPM:\
            meaning = "high". \
          31 BsPM ... 100 BsPM:\
            meaning = "critically high".\
\
\pard\pardeftab720\partightenfactor0

\f4\i0 \cf5 #------------------------------------------------------------------------\
\pard\pardeftab720\partightenfactor0

